rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // users: anyone signed in can read (needed to resolve display names in the UI);
    // only the owning user can write their own doc.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid);

      // FCM tokens: strictly owner-only. No cross-user visibility — tokens are
      // device credentials. Cloud Functions read via the Admin SDK and bypass
      // these rules.
      match /fcmTokens/{tokenId} {
        allow read, write: if isOwner(uid);
      }
    }

    // concerts: any signed-in user can read and create. Only the creator can
    // update / archive their own concert.
    match /concerts/{concertId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.createdBy == request.auth.uid;
      allow delete: if false;

      // comments: every signed-in user can read. Create is restricted to the
      // concert's creator and to current participants (a participation doc
      // exists at `participations/{concertId}_{uid}`). The author field must
      // match the caller, text length is 1..2000 chars, createdAt must be the
      // server timestamp, and only the four expected fields may be present.
      // Updates are allowed only by the original author and only to `text` /
      // `updatedAt` (server timestamp); other fields are pinned. Deletes are
      // forbidden. Update is not gated on current participation so an author
      // whose participation later goes away can still fix typos in their own
      // past comments.
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.keys().hasOnly(['text', 'authorId', 'authorDisplayName', 'createdAt'])
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() >= 1
          && request.resource.data.text.size() <= 2000
          && request.resource.data.createdAt == request.time
          && (
            get(/databases/$(database)/documents/concerts/$(concertId)).data.createdBy == request.auth.uid
            || exists(/databases/$(database)/documents/participations/$(concertId + '_' + request.auth.uid))
          );
        allow update: if isSignedIn()
          && resource.data.authorId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'updatedAt'])
          && request.resource.data.text is string
          && request.resource.data.text.size() >= 1
          && request.resource.data.text.size() <= 2000
          && request.resource.data.updatedAt == request.time;
        allow delete: if false;
      }
    }

    // participations: id convention is `${concertId}_${userId}`. A user can
    // create / delete only their own participation doc. Updates are allowed
    // either by the owning user (e.g. toggling hasTicket) or by any signed-in
    // user if the write only touches the `driverId` field — this lets a
    // driver assign/remove passengers and lets a leaving driver clear
    // driverId on passenger docs.
    //
    // Ticket-purchase tracking relaxes updates: any participant of a concert
    // may update only the ticket-related fields (`hasTicket`,
    // `ticketPurchasedBy`) on any participation for that concert, and
    // `ticketPurchasedBy`, when present, must equal the caller — you can only
    // mark yourself as the buyer.
    match /participations/{participationId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && participationId == request.resource.data.concertId + '_' + request.auth.uid;

      allow update: if isSignedIn()
        && (
          resource.data.userId == request.auth.uid
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['driverId'])
        );
      // any participant of the concert may update only the ticket-related fields
      // on any participation for that concert
      allow update: if isSignedIn()
        && exists(/databases/$(database)/documents/participations/$(resource.data.concertId + '_' + request.auth.uid))
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hasTicket', 'ticketPurchasedBy'])
        && request.resource.data.get('ticketPurchasedBy', request.auth.uid) == request.auth.uid;

      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }
  }
}
