# Firebase Configuration — Template
#
# For production: copy this file to .env.local and fill in the values for
#   the production Firebase project (default alias in .firebaserc).
# For staging: copy to .env.staging and fill in the values for the staging
#   Firebase project. npm run dev:staging / build:staging / deploy:staging
#   will load this file via Vite's --mode staging.
#
# Where to find each value:
#   Firebase Console → Project settings → General → Your apps →
#     SDK setup and configuration → Config. If no Web app is registered
#     yet, click the </> icon first and register one (do NOT tick
#     "Firebase Hosting" — we handle hosting separately).

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Web Push (Firebase Cloud Messaging)
# Firebase Console → Project settings → Cloud Messaging → Web configuration
# → Web Push certificates → Generate key pair → copy the public key here.
# Without this key the app cannot register for push notifications.
# Each project (prod / staging) has its own VAPID key — don't share.
VITE_FIREBASE_VAPID_KEY=your-vapid-public-key-here
